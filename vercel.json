{
  "version": 2,
  "redirects": [
    {
      "source": "/",
      "destination": "https://github.com/2061360308/media-metadata-proxy",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/tmdb/t/p/:path*",
      "destination": "https://image.tmdb.org/t/p/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/api/index.js"
    }
  ]
}
